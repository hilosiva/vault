{
  "name": "vaultcss",
  "version": "0.3.2",
  "description": "Unlock the Power of CSS",
  "license": "MIT",
  "author": "Shibata Hironori",
  "keywords": [
    "CSS",
    "CSS Library"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hilosiva/vault.git",
    "directory": "packages/vaultcss"
  },
  "bugs": "https://github.com/hilosiva/vault/issues",
  "homepage": "https://github.com/hilosiva/vault",
  "bin": {
    "vaultcss": "./dist/cli.mjs"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('./dist', {recursive:true,force:true})\"",
    "build": "tsup-node --env.NODE_ENV production",
    "dev": "tsup-node --env.NODE_ENV development --watch",
    "test": "vitest"
  },
  "exports": {
    ".": {
      "style": "./dist/index.css",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json",
    "./index.css": "./dist/index.css",
    "./index": "./dist/index.css",
    "./mediaqueries.css": "./dist/mediaqueries.css",
    "./mediaqueries": "./dist/mediaqueries.css",
    "./tokens/tokens.css": "./dist/tokens/tokens.css",
    "./tokens/tokens": "./dist/tokens/tokens.css",
    "./reset/reset.css": "./dist/reset/reset.css",
    "./reset/reset": "./dist/reset/reset.css",
    "./base/html.css": "./dist/base/html.css",
    "./base/html": "./dist/base/html.css",
    "./base/a.css": "./dist/base/a.css",
    "./base/a": "./dist/base/a.css",
    "./base/hn.css": "./dist/base/hn.css",
    "./base/hn": "./dist/base/hn.css",
    "./components/container.css": "./dist/components/container.css",
    "./components/container": "./dist/components/container.css",
    "./components/grid.css": "./dist/components/grid.css",
    "./components/grid": "./dist/components/grid.css",
    "./components/spacer.css": "./dist/components/spacer.css",
    "./components/spacer": "./dist/components/spacer.css",
    "./utilities/utilities.css": "./dist/utilities/utilities.css",
    "./utilities/utilities": "./dist/utilities/utilities.css"
  },
  "publishConfig": {
    "provenance": false,
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "style": "./dist/index.css",
        "require": "./dist/index.js",
        "import": "./dist/index.mjs"
      },
      "./package.json": "./package.json",
      "./index.css": "./dist/index.css",
      "./index": "./dist/index.css",
      "./mediaqueries.css": "./dist/mediaqueries.css",
      "./mediaqueries": "./dist/mediaqueries.css",
      "./tokens/tokens.css": "./dist/tokens/tokens.css",
      "./tokens/tokens": "./dist/tokens/tokens.css",
      "./reset/reset.css": "./dist/reset/reset.css",
      "./reset/reset": "./dist/reset/reset.css",
      "./base/html.css": "./dist/base/html.css",
      "./base/html": "./dist/base/html.css",
      "./base/a.css": "./dist/base/a.css",
      "./base/a": "./dist/base/a.css",
      "./base/hn.css": "./dist/base/hn.css",
      "./base/hn": "./dist/base/hn.css",
      "./components/container.css": "./dist/components/container.css",
      "./components/container": "./dist/components/container.css",
      "./components/grid.css": "./dist/components/grid.css",
      "./components/grid": "./dist/components/grid.css",
      "./components/spacer.css": "./dist/components/spacer.css",
      "./components/spacer": "./dist/components/spacer.css",
      "./utilities/utilities.css": "./dist/utilities/utilities.css",
      "./utilities/utilities": "./dist/utilities/utilities.css"
    }
  },
  "style": "dist/index.css",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^22.2.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "@hilosiva/oreset": "^4.0.0",
    "@inquirer/prompts": "5.1.2",
    "browserslist": "^4.24.4",
    "kolorist": "^1.8.0",
    "lightningcss": "^1.30.1",
    "lightningcss-plugin-fluid": "^0.0.7",
    "ora": "^9.3.0",
    "prettier": "^3.3.3"
  }
}
