{
  "name": "vaultcss-mcp",
  "version": "0.1.0",
  "description": "MCP server for vaultcss ecosystem",
  "license": "MIT",
  "author": "Shibata Hironori",
  "keywords": [
    "CSS",
    "MCP",
    "vaultcss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hilosiva/vault.git",
    "directory": "packages/vaultcss-mcp"
  },
  "bugs": "https://github.com/hilosiva/vault/issues",
  "homepage": "https://github.com/hilosiva/vault",
  "bin": {
    "vaultcss-mcp": "./dist/index.mjs"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('./dist', {recursive:true,force:true})\"",
    "build": "tsup-node",
    "dev": "tsup-node --watch"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": false,
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.2.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.25.0"
  }
}
